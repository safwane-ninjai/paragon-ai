# ─────────────────────────────────────────────
# .env.example — Paragon IA Onboarding Funnel
# Copie ce fichier en .env.local et remplis les valeurs.
# Ne jamais commiter .env.local (déjà dans .gitignore).
# ─────────────────────────────────────────────

# ── Airtable (étape 4 — création fiche artisan) ──────────────────────────────
AIRTABLE_API_KEY=patXXXXXXXXXXXXXX.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX
AIRTABLE_TABLE_ARTISANS=
AIRTABLE_TABLE_ABONNEMENTS=
AIRTABLE_TABLE_LEADS=

# ── Whop (étape 5 — enregistrement CB) ───────────────────────────────────────
WHOP_API_KEY=pik_0Di28yOQiKxFO_C4357248_C_b2061deb1f25269f5f7ee138a473d494c2502c85c84d8b1ddef1e46d325a04
WHOP_WEBHOOK_SECRET=
# ID du produit/plan Whop correspondant à chaque offre
WHOP_PLAN_STARTER_ID=plan_jdoZ8whYU3wIz
WHOP_PLAN_BOOSTER_ID=plan_cm18QL1I2qeul
WHOP_PLAN_CROISSANCE_ID=plan_9HP4WxiDMzpud

# ── DocuSeal (étape 6 — signature contrat) ───────────────────────────────────
DOCUSEAL_API_URL=https://docuseal.paragon-ia.tech
DOCUSEAL_API_KEY=xtUBAHgprZSV1QC7Yuahm2RsLptuxJq5X9QdzmH615U
# ID du template de contrat pré-configuré dans DocuSeal
DOCUSEAL_TEMPLATE_ID=3

# ── n8n (orchestration — webhooks entrants depuis Next.js) ───────────────────
N8N_BASE_URL=
# Clé secrète pour authentifier les appels Next.js → n8n
N8N_WEBHOOK_SECRET=
# URLs des webhooks spécifiques par déclencheur
N8N_WEBHOOK_COMPTE=
N8N_WEBHOOK_PAIEMENT=
N8N_WEBHOOK_CONTRAT=

# ── Resend (emails d'activation clients) ─────────────────────────────────────
RESEND_API_KEY=
# Expéditeur vérifié dans Resend (doit correspondre à un domaine validé)
RESEND_FROM_EMAIL=team@paragon-ia.com
# URL de l'espace membre Whop (ex: https://whop.com/paragon-ia/)
WHOP_HUB_URL=https://whop.com/hub/paragon-ia/

# ── Email Paragon IA (destinataire des PDF signés) ────────────────────────────
PARAGON_EMAIL_SUPPORT=serviceclient@paragon-ia.com
PARAGON_EMAIL_CONTRATS=

# ── Next.js ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL=http://localhost:3000
# Désactive l'indexation SEO en prod (NF5)
NEXT_PUBLIC_NO_INDEX=true
