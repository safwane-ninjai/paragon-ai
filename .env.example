# ─────────────────────────────────────────────
# .env.example — Paragon IA Onboarding Funnel
# Copie ce fichier en .env.local et remplis les valeurs.
# Ne jamais commiter .env.local (déjà dans .gitignore).
# ─────────────────────────────────────────────

# ── Airtable (étape 4 — création fiche artisan) ──────────────────────────────
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=
AIRTABLE_TABLE_ARTISANS=

# ── Whop (étape 5 — enregistrement CB) ───────────────────────────────────────
WHOP_API_KEY=
WHOP_WEBHOOK_SECRET=
# ID du produit/plan Whop correspondant à chaque offre
WHOP_PLAN_STARTER_ID=
WHOP_PLAN_BOOSTER_ID=
WHOP_PLAN_CROISSANCE_ID=

# ── DocuSeal (étape 6 — signature contrat) ───────────────────────────────────
DOCUSEAL_API_URL=https://docuseal.paragon-ia.tech
DOCUSEAL_API_KEY=
# ID du template de contrat pré-configuré dans DocuSeal
DOCUSEAL_TEMPLATE_ID=

# ── n8n (orchestration — webhooks entrants depuis Next.js) ───────────────────
N8N_BASE_URL=
# Clé secrète pour authentifier les appels Next.js → n8n
N8N_WEBHOOK_SECRET=
# URLs des webhooks spécifiques par déclencheur
N8N_WEBHOOK_COMPTE=
N8N_WEBHOOK_PAIEMENT=
N8N_WEBHOOK_CONTRAT=

# ── Email Paragon IA (destinataire des PDF signés) ────────────────────────────
PARAGON_EMAIL_SUPPORT=serviceclient@paragon-ia.com
PARAGON_EMAIL_CONTRATS=

# ── Next.js ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL=http://localhost:3000
# Désactive l'indexation SEO en prod (NF5)
NEXT_PUBLIC_NO_INDEX=true
